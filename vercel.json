{
  "framework": "astro",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "redirects": [
    {
      "source": "/growth/solution/",
      "destination": "/growth/",
      "permanent": true
    },
    {
      "source": "/growth/solution/index.html",
      "destination": "/growth/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(preview|search|tags|thanks|test|tests)/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/growth/(solution|preview|search|test|tests)/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/growth/(demo|lp)/thanks/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ]
}
