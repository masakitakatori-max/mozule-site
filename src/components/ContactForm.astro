---
interface Props {
  context?: string;
  submitLabel?: string;
}

const { context = 'general', submitLabel = 'フォームを送信する' } = Astro.props;
const inputClass =
  'w-full rounded-lg border border-[#2A2A2A] bg-[#0A0A0A] px-4 py-3 text-sm text-white outline-none transition placeholder:text-gray-600 focus:border-[#4DB6AC]';
const fallbackContactEmail = 'org-owner@mozule.co.jp';
---
<form
  class="contact-form text-left"
  action="/api/contact"
  method="post"
  data-contact-form
>
  <input type="hidden" name="context" value={context} />
  <label class="hidden" aria-hidden="true">
    Website
    <input type="text" name="website" tabindex="-1" autocomplete="off" />
  </label>

  <div class="grid gap-5 md:grid-cols-2">
    <label class="block">
      <span class="mb-2 block text-xs font-semibold tracking-widest text-gray-500">NAME</span>
      <input class={inputClass} name="name" autocomplete="name" required placeholder="お名前" />
    </label>
    <label class="block">
      <span class="mb-2 block text-xs font-semibold tracking-widest text-gray-500">COMPANY</span>
      <input class={inputClass} name="company" autocomplete="organization" placeholder="会社名" />
    </label>
    <label class="block">
      <span class="mb-2 block text-xs font-semibold tracking-widest text-gray-500">EMAIL</span>
      <input class={inputClass} type="email" name="email" autocomplete="email" required placeholder="name@example.com" />
    </label>
    <label class="block">
      <span class="mb-2 block text-xs font-semibold tracking-widest text-gray-500">TOPIC</span>
      <select class={inputClass} name="topic" required>
        <option value="">選択してください</option>
        <option value="mozule growth">mozule growth</option>
        <option value="SEO/AEO">SEO/AEO</option>
        <option value="AI/MCP/GitHub">AI/MCP/GitHub</option>
        <option value="Corporate">会社・事業について</option>
        <option value="Other">その他</option>
      </select>
    </label>
  </div>

  <label class="mt-5 block">
    <span class="mb-2 block text-xs font-semibold tracking-widest text-gray-500">URL</span>
    <input class={inputClass} type="url" name="targetUrl" placeholder="https://example.com" />
  </label>

  <label class="mt-5 block">
    <span class="mb-2 block text-xs font-semibold tracking-widest text-gray-500">MESSAGE</span>
    <textarea
      class={`${inputClass} min-h-36 resize-y`}
      name="message"
      required
      placeholder="相談したい内容を記入してください"
    ></textarea>
  </label>

  <div class="mt-6 flex flex-col gap-4 sm:flex-row sm:items-center">
    <button
      type="submit"
      class="inline-flex items-center justify-center rounded-lg bg-[#4DB6AC] px-8 py-4 text-sm font-bold text-white transition hover:-translate-y-0.5 hover:bg-[#00897B] disabled:cursor-not-allowed disabled:opacity-60"
    >
      {submitLabel}
    </button>
    <div class="flex flex-col gap-2">
      <p class="text-sm text-gray-500" data-contact-status aria-live="polite"></p>
      <a
        href={`mailto:${fallbackContactEmail}`}
        class="hidden text-sm font-medium text-[#4DB6AC] underline underline-offset-4 hover:text-white"
        data-contact-fallback
      >
        メールアプリで直接送る
      </a>
    </div>
  </div>
</form>

<script>
  const fallbackContactEmail = 'org-owner@mozule.co.jp';
  const buildFallbackMailto = (form) => {
    const formData = new FormData(form);
    const context = String(formData.get('context') || 'general');
    const topic = String(formData.get('topic') || 'Inquiry');
    const name = String(formData.get('name') || '');
    const company = String(formData.get('company') || '');
    const email = String(formData.get('email') || '');
    const targetUrl = String(formData.get('targetUrl') || '');
    const message = String(formData.get('message') || '');
    const subject = `[Mozule] ${topic} inquiry from ${name || 'Website visitor'}`;
    const body = [
      `Context: ${context}`,
      `Name: ${name}`,
      `Company: ${company || '-'}`,
      `Email: ${email}`,
      `Topic: ${topic}`,
      `Target URL: ${targetUrl || '-'}`,
      '',
      message,
    ].join('\n');

    return `mailto:${fallbackContactEmail}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
  };

  document.querySelectorAll('[data-contact-form]').forEach((form) => {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const target = event.currentTarget;
      if (!(target instanceof HTMLFormElement)) return;

      const status = target.querySelector('[data-contact-status]');
      const button = target.querySelector('button[type="submit"]');
      const fallbackLink = target.querySelector('[data-contact-fallback]');
      const setStatus = (message, isError = false) => {
        if (!status) return;
        status.textContent = message;
        status.classList.toggle('text-red-300', isError);
        status.classList.toggle('text-gray-500', !isError);
      };
      const revealFallback = () => {
        if (!(fallbackLink instanceof HTMLAnchorElement)) return;
        fallbackLink.href = buildFallbackMailto(target);
        fallbackLink.classList.remove('hidden');
      };
      const launchFallback = () => {
        const href = buildFallbackMailto(target);
        revealFallback();
        window.location.href = href;
      };

      if (button instanceof HTMLButtonElement) button.disabled = true;
      setStatus('送信中です。');
      if (fallbackLink instanceof HTMLAnchorElement) {
        fallbackLink.classList.add('hidden');
      }

      try {
        const formData = new FormData(target);
        const body = new URLSearchParams();
        formData.forEach((value, key) => body.append(key, String(value)));

        const response = await fetch(target.action, {
          method: 'POST',
          body,
          headers: {
            Accept: 'application/json',
            'Content-Type': 'application/x-www-form-urlencoded',
          },
        });
        const result = await response.json().catch(() => ({}));

        if (!response.ok) {
          if (response.status === 404 || response.status >= 500) {
            launchFallback();
            throw new Error('フォーム送信を利用できません。下のリンクから直接メールしてください。');
          }
          throw new Error(result.message || '送信できませんでした。');
        }

        target.reset();
        setStatus('送信しました。確認後にご連絡します。');
      } catch (error) {
        if (error instanceof TypeError) {
          launchFallback();
        } else {
          revealFallback();
        }
        setStatus(error instanceof Error ? error.message : '送信できませんでした。', true);
      } finally {
        if (button instanceof HTMLButtonElement) button.disabled = false;
      }
    });
  });
</script>
