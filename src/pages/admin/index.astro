---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { adminSeoPages, adminSeoSummary, adminTopicClusters, seoActionLibrary } from '../../data/adminSeo';

const focusPages = adminSeoPages
  .map((page, index) => ({ page, index }))
  .sort((a, b) => a.page.score - b.page.score)
  .slice(0, 8);
const adminData = JSON.stringify(adminSeoPages);
const clusterData = JSON.stringify(adminTopicClusters);
---
<AdminLayout title="SEO Control Room">
  <script id="admin-seo-data" type="application/json" set:html={adminData}></script>
  <script id="admin-cluster-data" type="application/json" set:html={clusterData}></script>

  <div class="min-h-screen">
    <header class="sticky top-0 z-40 border-b border-white/10 bg-[#0B0D10]/90 backdrop-blur-xl">
      <div class="mx-auto flex h-16 max-w-[1480px] items-center justify-between px-5">
        <div class="flex items-center gap-4">
          <a href="/growth/" class="text-sm font-bold tracking-tight text-white">mozule growth</a>
          <span class="h-5 w-px bg-white/10"></span>
          <p class="text-sm font-semibold text-gray-300">SEO Control Room</p>
        </div>
        <div class="flex items-center gap-3">
          <span class="hidden rounded-full border border-amber-400/30 bg-amber-400/10 px-3 py-1 text-xs font-medium text-amber-200 md:inline-flex">Cloudflare Accessで保護推奨</span>
          <button type="button" class="inline-flex h-9 items-center gap-2 rounded-md border border-white/10 px-3 text-xs font-semibold text-gray-200 transition hover:border-[#4DB6AC] hover:text-white" data-copy-plan>
            <svg aria-hidden="true" viewBox="0 0 20 20" class="h-4 w-4 fill-current"><path d="M5 2a2 2 0 0 0-2 2v10h2V4h9V2H5Zm4 4a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2H9Zm0 2h6v8H9V8Z"/></svg>
            変更案をコピー
          </button>
        </div>
      </div>
    </header>

    <div class="mx-auto grid max-w-[1480px] grid-cols-1 gap-0 lg:grid-cols-[248px_minmax(0,1fr)]">
      <aside class="border-b border-white/10 bg-[#0F1216] px-5 py-5 lg:min-h-[calc(100vh-64px)] lg:border-b-0 lg:border-r">
        <nav class="space-y-1" aria-label="Admin sections">
          {[
            { label: 'Dashboard', meta: '今日の改善', href: '#section-0' },
            { label: 'Pages', meta: 'ページ別SEO', href: '#section-1' },
            { label: 'Content', meta: '本文編集', href: '#section-6' },
            { label: 'Visual', meta: '見た目編集', href: '#section-7' },
            { label: 'Opportunities', meta: '改善候補', href: '#section-2' },
            { label: 'Clusters', meta: 'ノード可視化', href: '#section-3' },
            { label: 'Schema', meta: '構造化データ', href: '#section-4' },
            { label: 'Indexing', meta: '公開制御', href: '#section-5' },
          ].map((item, index) => (
            <a href={item.href} class={`flex items-center justify-between rounded-md px-3 py-3 text-sm transition ${index === 0 ? 'bg-[#4DB6AC]/15 text-white' : 'text-gray-400 hover:bg-white/5 hover:text-white'}`}>
              <span class="font-semibold">{item.label}</span>
              <span class="text-xs text-gray-500">{item.meta}</span>
            </a>
          ))}
        </nav>

        <div class="mt-8 border-t border-white/10 pt-6">
          <p class="text-xs font-semibold uppercase tracking-widest text-gray-500">Safety</p>
          <div class="mt-4 space-y-3 text-sm text-gray-400">
            <p class="flex gap-2"><span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-[#4DB6AC]"></span>noindexページはsitemapから除外</p>
            <p class="flex gap-2"><span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-amber-400"></span>canonicalとnoindexの併用を警告</p>
            <p class="flex gap-2"><span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-sky-400"></span>公開前にPR差分を確認</p>
          </div>
        </div>
      </aside>

      <main class="min-w-0 px-5 py-6 md:px-8">
        <section id="section-0" class="grid gap-5 xl:grid-cols-[1fr_360px]">
          <div class="rounded-lg border border-white/10 bg-[#11151A] p-5">
            <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-[#4DB6AC]">Manual SEO workspace</p>
                <h1 class="mt-3 text-3xl font-extrabold tracking-tight text-white md:text-4xl">専門家のSEO判断を、非エンジニアの操作に落とす</h1>
                <p class="mt-3 max-w-3xl text-sm leading-6 text-gray-400">ページを選ぶと、KW/THP、AIO、E-E-A-T、内部リンク、構造化データ、index制御の改善カードだけが出ます。公開書き換えAPIは未接続なので、まずはPR前提の安全な作業台です。</p>
              </div>
              <div class="grid grid-cols-2 gap-3 sm:grid-cols-5 md:w-[640px]">
                <div class="rounded-md border border-white/10 bg-black/20 p-3">
                  <p class="text-xs text-gray-500">Pages</p>
                  <p class="mt-1 text-2xl font-bold text-white">{adminSeoSummary.pageCount}</p>
                </div>
                <div class="rounded-md border border-white/10 bg-black/20 p-3">
                  <p class="text-xs text-gray-500">Priority</p>
                  <p class="mt-1 text-2xl font-bold text-amber-200">{adminSeoSummary.highPriorityCount}</p>
                </div>
                <div class="rounded-md border border-white/10 bg-black/20 p-3">
                  <p class="text-xs text-gray-500">Articles</p>
                  <p class="mt-1 text-2xl font-bold text-white">{adminSeoSummary.articleCount}</p>
                </div>
                <div class="rounded-md border border-white/10 bg-black/20 p-3">
                  <p class="text-xs text-gray-500">Clusters</p>
                  <p class="mt-1 text-2xl font-bold text-white">{adminSeoSummary.clusterCount}</p>
                </div>
                <div class="rounded-md border border-white/10 bg-black/20 p-3">
                  <p class="text-xs text-gray-500">Avg score</p>
                  <p class="mt-1 text-2xl font-bold text-[#4DB6AC]">{adminSeoSummary.averageScore}</p>
                </div>
              </div>
            </div>

            <div class="mt-6 grid gap-3 md:grid-cols-2 xl:grid-cols-4">
              {seoActionLibrary.slice(0, 8).map((action) => (
                <button type="button" class="group min-h-[120px] rounded-md border border-white/10 bg-[#0B0D10] p-4 text-left transition hover:border-[#4DB6AC]/70 hover:bg-[#111E20]">
                  <span class="text-xs font-semibold text-gray-500">{action.category}</span>
                  <span class="mt-3 block text-sm font-bold leading-5 text-white">{action.label}</span>
                  <span class="mt-3 inline-flex items-center gap-2 text-xs font-semibold text-[#4DB6AC] group-hover:text-white">
                    {action.oneClick}
                    <svg aria-hidden="true" viewBox="0 0 20 20" class="h-3.5 w-3.5 fill-current"><path d="m12.3 4.3-1.4 1.4L14.2 9H3v2h11.2l-3.3 3.3 1.4 1.4L18 10l-5.7-5.7Z"/></svg>
                  </span>
                </button>
              ))}
            </div>
          </div>

          <div class="rounded-lg border border-white/10 bg-[#11151A] p-5">
            <div class="flex items-center justify-between">
              <h2 class="text-base font-bold text-white">今日の優先ページ</h2>
              <span class="rounded-full bg-amber-400/10 px-2.5 py-1 text-xs font-semibold text-amber-200">Score低順</span>
            </div>
            <div class="mt-4 space-y-2">
              {focusPages.map(({ page, index }) => (
                <button type="button" data-page-index={index} class="page-pick flex w-full items-center justify-between gap-3 rounded-md border border-white/10 bg-black/20 px-3 py-3 text-left transition hover:border-[#4DB6AC]/70">
                  <span class="min-w-0">
                    <span class="block truncate text-sm font-semibold text-white">{page.title}</span>
                    <span class="block truncate text-xs text-gray-500">{page.primaryKeyword}</span>
                  </span>
                  <span class={`shrink-0 rounded-full px-2 py-1 text-xs font-bold ${page.score >= 88 ? 'bg-[#4DB6AC]/15 text-[#4DB6AC]' : page.score >= 76 ? 'bg-amber-400/10 text-amber-200' : 'bg-rose-500/10 text-rose-200'}`}>{page.score}</span>
                </button>
              ))}
            </div>
          </div>
        </section>

        <section id="section-1" class="mt-6 grid gap-5 xl:grid-cols-[420px_minmax(0,1fr)]">
          <div class="rounded-lg border border-white/10 bg-[#11151A]">
            <div class="border-b border-white/10 p-4">
              <label class="block text-xs font-semibold uppercase tracking-widest text-gray-500" for="page-search">Pages</label>
              <div class="mt-3 flex items-center gap-2 rounded-md border border-white/10 bg-black/20 px-3">
                <svg aria-hidden="true" viewBox="0 0 20 20" class="h-4 w-4 fill-gray-500"><path d="M8.5 3a5.5 5.5 0 1 0 3.3 9.9l3.6 3.6 1.4-1.4-3.6-3.6A5.5 5.5 0 0 0 8.5 3Zm0 2a3.5 3.5 0 1 1 0 7 3.5 3.5 0 0 1 0-7Z"/></svg>
                <input id="page-search" data-page-search class="h-10 w-full bg-transparent text-sm text-white outline-none placeholder:text-gray-600" placeholder="KW、URL、タイトルで検索" />
              </div>
            </div>
            <div class="max-h-[760px] overflow-y-auto p-2" data-page-list>
              {adminSeoPages.map((page, index) => (
                <button type="button" data-page-row data-page-index={index} data-search={`${page.title} ${page.path} ${page.primaryKeyword}`} class="page-row flex w-full gap-3 rounded-md px-3 py-3 text-left transition hover:bg-white/5">
                  <span class={`mt-1 h-2.5 w-2.5 shrink-0 rounded-full ${page.score >= 88 ? 'bg-[#4DB6AC]' : page.score >= 76 ? 'bg-amber-400' : 'bg-rose-400'}`}></span>
                  <span class="min-w-0 flex-1">
                    <span class="block truncate text-sm font-semibold text-white">{page.title}</span>
                    <span class="mt-1 block truncate text-xs text-gray-500">{page.path}</span>
                    <span class="mt-2 inline-flex rounded-full border border-white/10 px-2 py-1 text-[11px] font-medium text-gray-400">{page.primaryKeyword}</span>
                  </span>
                  <span class="text-sm font-bold text-gray-300">{page.score}</span>
                </button>
              ))}
            </div>
          </div>

          <div class="rounded-lg border border-white/10 bg-[#11151A]">
            <div class="border-b border-white/10 p-5">
              <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                <div class="min-w-0">
                  <p class="text-xs font-semibold uppercase tracking-widest text-[#4DB6AC]" data-page-schema>Service</p>
                  <h2 class="mt-2 truncate text-2xl font-extrabold text-white" data-page-title>Page title</h2>
                  <p class="mt-2 truncate text-sm text-gray-500" data-page-path>/growth/</p>
                </div>
                <div class="flex items-center gap-3">
                  <div class="h-16 w-16 rounded-full border-4 border-[#4DB6AC]/30 p-1">
                    <div class="flex h-full w-full items-center justify-center rounded-full bg-[#4DB6AC]/10 text-lg font-extrabold text-[#4DB6AC]" data-page-score>0</div>
                  </div>
                  <div>
                    <p class="text-xs text-gray-500">Readiness</p>
                    <p class="text-sm font-semibold text-gray-300" data-page-health>Needs review</p>
                  </div>
                </div>
              </div>
            </div>

            <div class="grid gap-0 xl:grid-cols-[minmax(0,1fr)_360px]">
              <div class="border-b border-white/10 p-5 xl:border-b-0 xl:border-r">
                <div class="grid gap-4 md:grid-cols-2">
                  <label class="block">
                    <span class="text-xs font-semibold text-gray-500">Target KW</span>
                    <input data-field="primaryKeyword" class="mt-2 h-11 w-full rounded-md border border-white/10 bg-black/20 px-3 text-sm text-white outline-none focus:border-[#4DB6AC]" />
                  </label>
                  <label class="block">
                    <span class="text-xs font-semibold text-gray-500">URL</span>
                    <input data-field="path" class="mt-2 h-11 w-full rounded-md border border-white/10 bg-black/20 px-3 text-sm text-gray-300 outline-none focus:border-[#4DB6AC]" readonly />
                  </label>
                  <label class="block md:col-span-2">
                    <span class="text-xs font-semibold text-gray-500">Title</span>
                    <input data-field="title" class="mt-2 h-11 w-full rounded-md border border-white/10 bg-black/20 px-3 text-sm text-white outline-none focus:border-[#4DB6AC]" />
                  </label>
                  <label class="block md:col-span-2">
                    <span class="text-xs font-semibold text-gray-500">Description</span>
                    <textarea data-field="description" rows="3" class="mt-2 w-full resize-none rounded-md border border-white/10 bg-black/20 px-3 py-3 text-sm leading-6 text-white outline-none focus:border-[#4DB6AC]"></textarea>
                  </label>
                  <label class="block md:col-span-2">
                    <span class="text-xs font-semibold text-gray-500">AIO/AEO conclusion block</span>
                    <textarea data-field="lede" rows="4" class="mt-2 w-full resize-none rounded-md border border-white/10 bg-black/20 px-3 py-3 text-sm leading-6 text-white outline-none focus:border-[#4DB6AC]"></textarea>
                  </label>
                </div>

                <div class="mt-6 rounded-md border border-white/10 bg-[#0B0D10] p-4">
                  <div class="flex items-center justify-between">
                    <h3 class="text-sm font-bold text-white">公開制御</h3>
                    <span class="text-xs text-gray-500">noindex/canonical/sitemap</span>
                  </div>
                  <div class="mt-4 grid gap-3 md:grid-cols-3">
                    <label class="block">
                      <span class="text-xs text-gray-500">Index</span>
                      <select data-index-status class="mt-2 h-10 w-full rounded-md border border-white/10 bg-black/30 px-3 text-sm text-white outline-none focus:border-[#4DB6AC]">
                        <option value="index">検索に出す</option>
                        <option value="noindex">検索に出さない</option>
                      </select>
                    </label>
                    <label class="block md:col-span-2">
                      <span class="text-xs text-gray-500">Canonical</span>
                      <input data-canonical class="mt-2 h-10 w-full rounded-md border border-white/10 bg-black/30 px-3 text-sm text-white outline-none focus:border-[#4DB6AC]" />
                    </label>
                    <label class="flex items-center gap-3 rounded-md border border-white/10 bg-black/20 px-3 py-3 md:col-span-3">
                      <input data-sitemap type="checkbox" checked class="h-4 w-4 accent-[#4DB6AC]" />
                      <span class="text-sm text-gray-300">sitemap.xmlに掲載する</span>
                    </label>
                  </div>
                  <p class="mt-4 rounded-md border border-white/10 bg-black/20 px-3 py-2 text-sm text-gray-300" data-index-message>安全です。</p>
                </div>
              </div>

              <aside class="p-5">
                <div class="flex items-center justify-between">
                  <h3 class="text-sm font-bold text-white">改善カード</h3>
                  <span class="text-xs text-gray-500" data-task-count>0件</span>
                </div>
                <div class="mt-4 space-y-3" data-task-list></div>

                <div class="mt-6 rounded-md border border-white/10 bg-black/20 p-4">
                  <h3 class="text-sm font-bold text-white">公開フロー</h3>
                  <ol class="mt-4 space-y-3 text-sm text-gray-400">
                    <li class="flex gap-3"><span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#4DB6AC]/15 text-xs font-bold text-[#4DB6AC]">1</span>下書きを保存</li>
                    <li class="flex gap-3"><span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#4DB6AC]/15 text-xs font-bold text-[#4DB6AC]">2</span>差分を確認</li>
                    <li class="flex gap-3"><span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#4DB6AC]/15 text-xs font-bold text-[#4DB6AC]">3</span>GitHub PRを作成</li>
                    <li class="flex gap-3"><span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#4DB6AC]/15 text-xs font-bold text-[#4DB6AC]">4</span>Cloudflareで公開</li>
                  </ol>
                  <button type="button" data-submit-proposal class="mt-5 flex h-10 w-full items-center justify-center rounded-md bg-[#4DB6AC] text-sm font-bold text-white transition hover:bg-[#00897B]">
                    PR作成リクエスト
                  </button>
                  <p class="mt-3 min-h-10 rounded-md border border-white/10 bg-black/20 px-3 py-2 text-xs leading-5 text-gray-400" data-submit-status>Cloudflare AccessまたはADMIN_TOKEN設定後にPR作成できます。</p>
                </div>
              </aside>
            </div>
          </div>
        </section>

        <section id="section-6" class="mt-6 rounded-lg border border-white/10 bg-[#11151A] p-5">
          <div class="flex flex-col gap-3 xl:flex-row xl:items-end xl:justify-between">
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-[#4DB6AC]">Rich text CMS</p>
              <h2 class="mt-2 text-xl font-bold text-white">HTML本文をブロック単位で編集</h2>
              <p class="mt-2 max-w-3xl text-sm leading-6 text-gray-400">見出し、太字、リスト、引用、リンク、画像枠をここで編集します。保存するとGitHub PRで `sections` に反映されます。</p>
            </div>
            <div class="flex flex-wrap gap-2">
              <button type="button" data-section-add class="rounded-md border border-[#4DB6AC]/40 px-3 py-2 text-xs font-bold text-[#B2DFDB] transition hover:bg-[#4DB6AC]/10">セクション追加</button>
              <button type="button" data-section-duplicate class="rounded-md border border-white/10 px-3 py-2 text-xs font-bold text-gray-300 transition hover:border-[#4DB6AC]/60">複製</button>
              <button type="button" data-section-delete class="rounded-md border border-rose-400/30 px-3 py-2 text-xs font-bold text-rose-200 transition hover:bg-rose-500/10">削除</button>
            </div>
          </div>

          <div class="mt-5 grid gap-5 xl:grid-cols-[280px_minmax(0,1fr)_340px]">
            <div class="rounded-md border border-white/10 bg-black/20">
              <div class="border-b border-white/10 p-4">
                <p class="text-xs font-semibold uppercase tracking-widest text-gray-500">Sections</p>
              </div>
              <div class="max-h-[560px] overflow-y-auto p-2" data-section-list></div>
            </div>

            <div class="rounded-md border border-white/10 bg-[#0B0D10] p-4">
              <label class="block">
                <span class="text-xs font-semibold text-gray-500">Section heading</span>
                <input data-section-title class="mt-2 h-11 w-full rounded-md border border-white/10 bg-black/30 px-3 text-sm font-semibold text-white outline-none focus:border-[#4DB6AC]" />
              </label>

              <div class="mt-4 flex flex-wrap items-center gap-2 rounded-md border border-white/10 bg-black/20 p-2">
                {[
                  ['p', 'P'],
                  ['h2', 'H2'],
                  ['h3', 'H3'],
                  ['blockquote', '引用'],
                ].map(([block, label]) => (
                  <button type="button" data-format-block={block} class="h-8 rounded-md border border-white/10 px-2 text-xs font-bold text-gray-300 transition hover:border-[#4DB6AC]/60 hover:text-white">{label}</button>
                ))}
                <span class="mx-1 h-5 w-px bg-white/10"></span>
                {[
                  ['bold', 'B'],
                  ['italic', 'I'],
                  ['underline', 'U'],
                  ['insertUnorderedList', '• List'],
                ].map(([command, label]) => (
                  <button type="button" data-rich-command={command} class="h-8 rounded-md border border-white/10 px-2 text-xs font-bold text-gray-300 transition hover:border-[#4DB6AC]/60 hover:text-white">{label}</button>
                ))}
                <button type="button" data-rich-link class="h-8 rounded-md border border-white/10 px-2 text-xs font-bold text-gray-300 transition hover:border-[#4DB6AC]/60 hover:text-white">Link</button>
              </div>

              <div data-rich-editor contenteditable="true" spellcheck="false" class="mt-3 min-h-[280px] rounded-md border border-white/10 bg-black/20 px-4 py-4 text-sm leading-7 text-gray-100 outline-none focus:border-[#4DB6AC]"></div>

              <label class="mt-4 block">
                <span class="text-xs font-semibold text-gray-500">Bullet items</span>
                <textarea data-section-items rows="4" class="mt-2 w-full resize-none rounded-md border border-white/10 bg-black/20 px-3 py-3 text-sm leading-6 text-white outline-none focus:border-[#4DB6AC]" placeholder="1行に1項目"></textarea>
              </label>
            </div>

            <aside class="rounded-md border border-white/10 bg-black/20 p-4">
              <p class="text-xs font-semibold uppercase tracking-widest text-[#4DB6AC]">Image slot</p>
              <p class="mt-2 text-sm leading-6 text-gray-400">画像を入れる場所をここで決めます。まずはURL指定、次フェーズでアップロード/R2保管にできます。</p>
              <label class="mt-4 block">
                <span class="text-xs text-gray-500">Image URL</span>
                <input data-section-image-src class="mt-2 h-10 w-full rounded-md border border-white/10 bg-black/30 px-3 text-sm text-white outline-none focus:border-[#4DB6AC]" placeholder="/images/example.webp or https://..." />
              </label>
              <label class="mt-3 block">
                <span class="text-xs text-gray-500">Alt text</span>
                <input data-section-image-alt class="mt-2 h-10 w-full rounded-md border border-white/10 bg-black/30 px-3 text-sm text-white outline-none focus:border-[#4DB6AC]" />
              </label>
              <label class="mt-3 block">
                <span class="text-xs text-gray-500">Caption</span>
                <input data-section-image-caption class="mt-2 h-10 w-full rounded-md border border-white/10 bg-black/30 px-3 text-sm text-white outline-none focus:border-[#4DB6AC]" />
              </label>
              <div class="mt-4 grid grid-cols-2 gap-2">
                <button type="button" data-section-up class="h-9 rounded-md border border-white/10 text-xs font-bold text-gray-300 transition hover:border-[#4DB6AC]/60">上へ</button>
                <button type="button" data-section-down class="h-9 rounded-md border border-white/10 text-xs font-bold text-gray-300 transition hover:border-[#4DB6AC]/60">下へ</button>
              </div>
              <p class="mt-4 rounded-md border border-white/10 bg-[#0B0D10] px-3 py-2 text-xs leading-5 text-gray-400" data-content-status>ページを選ぶと本文ブロックを編集できます。</p>
            </aside>
          </div>
        </section>

        <section id="section-7" class="mt-6 rounded-lg border border-white/10 bg-[#11151A] p-5">
          <div class="flex flex-col gap-3 xl:flex-row xl:items-end xl:justify-between">
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-[#4DB6AC]">Visual editor</p>
              <h2 class="mt-2 text-xl font-bold text-white">ページの見た目をキャンバスで編集</h2>
              <p class="mt-2 max-w-3xl text-sm leading-6 text-gray-400">セクションを選び、レイアウト、トーン、文字サイズ、揃えを変えます。公開ページと同じデータに保存されます。</p>
            </div>
            <a href="/growth/" target="_blank" rel="noreferrer" class="rounded-md border border-white/10 px-3 py-2 text-xs font-bold text-gray-300 transition hover:border-[#4DB6AC]/60">公開ページを開く</a>
          </div>

          <div class="mt-5 grid gap-5 xl:grid-cols-[minmax(0,1fr)_320px]">
            <div class="overflow-hidden rounded-md border border-white/10 bg-[#06080B]">
              <div class="border-b border-white/10 px-4 py-3 text-xs font-semibold uppercase tracking-widest text-gray-500">Canvas preview</div>
              <div class="max-h-[720px] overflow-y-auto" data-visual-canvas></div>
            </div>

            <aside class="rounded-md border border-white/10 bg-black/20 p-4">
              <p class="text-xs font-semibold uppercase tracking-widest text-[#4DB6AC]">Inspector</p>
              <h3 class="mt-2 text-sm font-bold text-white" data-visual-selected-title>Section</h3>
              <div class="mt-4 space-y-3">
                <label class="block">
                  <span class="text-xs text-gray-500">Layout</span>
                  <select data-visual-layout class="mt-2 h-10 w-full rounded-md border border-white/10 bg-black/30 px-3 text-sm text-white outline-none focus:border-[#4DB6AC]">
                    <option value="text">Text only</option>
                    <option value="split-right">Text / Image</option>
                    <option value="split-left">Image / Text</option>
                    <option value="feature">Wide feature</option>
                  </select>
                </label>
                <label class="block">
                  <span class="text-xs text-gray-500">Tone</span>
                  <select data-visual-tone class="mt-2 h-10 w-full rounded-md border border-white/10 bg-black/30 px-3 text-sm text-white outline-none focus:border-[#4DB6AC]">
                    <option value="default">Default</option>
                    <option value="muted">Muted band</option>
                    <option value="accent">Accent band</option>
                    <option value="light">Light block</option>
                  </select>
                </label>
                <label class="block">
                  <span class="text-xs text-gray-500">Text align</span>
                  <select data-visual-align class="mt-2 h-10 w-full rounded-md border border-white/10 bg-black/30 px-3 text-sm text-white outline-none focus:border-[#4DB6AC]">
                    <option value="left">Left</option>
                    <option value="center">Center</option>
                  </select>
                </label>
                <label class="block">
                  <span class="text-xs text-gray-500">Heading size</span>
                  <select data-visual-heading-size class="mt-2 h-10 w-full rounded-md border border-white/10 bg-black/30 px-3 text-sm text-white outline-none focus:border-[#4DB6AC]">
                    <option value="md">Medium</option>
                    <option value="lg">Large</option>
                    <option value="xl">XL</option>
                  </select>
                </label>
                <label class="block">
                  <span class="text-xs text-gray-500">Body size</span>
                  <select data-visual-body-size class="mt-2 h-10 w-full rounded-md border border-white/10 bg-black/30 px-3 text-sm text-white outline-none focus:border-[#4DB6AC]">
                    <option value="sm">Small</option>
                    <option value="md">Medium</option>
                    <option value="lg">Large</option>
                  </select>
                </label>
              </div>
              <p class="mt-4 rounded-md border border-white/10 bg-[#0B0D10] px-3 py-2 text-xs leading-5 text-gray-400">自由配置/ドラッグリサイズは次フェーズで、まずはSEOページとして崩れない範囲の見た目編集に絞っています。</p>
            </aside>
          </div>
        </section>

        <section id="section-2" class="mt-6 grid gap-5 xl:grid-cols-3">
          {[
            ['低CTR改善', 'Titleとdescriptionを検索意図に合わせ、上部に短い回答を置く。', 'KW・THP / UX'],
            ['AIO引用準備', '150-200字の結論、箇条書き、FAQ、構造化データを同時に確認する。', 'AIO'],
            ['重複・未登録対策', 'canonical、noindex、301、sitemap掲載をページ単位で矛盾なく制御する。', 'ネガティブ要素'],
          ].map(([title, body, source]) => (
            <article class="rounded-lg border border-white/10 bg-[#11151A] p-5">
              <p class="text-xs font-semibold uppercase tracking-widest text-[#4DB6AC]">{source}</p>
              <h2 class="mt-3 text-lg font-bold text-white">{title}</h2>
              <p class="mt-3 text-sm leading-6 text-gray-400">{body}</p>
            </article>
          ))}
        </section>

        <section id="section-3" class="mt-6 rounded-lg border border-white/10 bg-[#11151A] p-5">
          <div class="flex flex-col gap-4 xl:flex-row xl:items-end xl:justify-between">
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-[#4DB6AC]">Topic Cluster Map</p>
              <h2 class="mt-2 text-xl font-bold text-white">ノードで見るSEOクラスター</h2>
              <p class="mt-2 max-w-3xl text-sm leading-6 text-gray-400">中心ノードがピラー、外側が商用LP・コラム・比較・連携ページです。ノードを押すと編集対象ページが切り替わります。</p>
            </div>
            <div class="grid grid-cols-2 gap-2 sm:grid-cols-5">
              {adminTopicClusters.map((cluster, index) => (
                <button type="button" data-cluster-id={cluster.id} class={`cluster-pick rounded-md border px-3 py-2 text-left transition ${index === 0 ? 'border-[#4DB6AC]/70 bg-[#4DB6AC]/15' : 'border-white/10 bg-black/20 hover:border-[#4DB6AC]/60'}`}>
                  <span class="block truncate text-xs font-bold text-white">{cluster.label}</span>
                  <span class="mt-1 block text-[11px] text-gray-500">{cluster.nodeCount} nodes / {cluster.averageScore}</span>
                </button>
              ))}
            </div>
          </div>

          <div class="mt-5 grid gap-5 xl:grid-cols-[minmax(0,1fr)_360px]">
            <div class="relative min-h-[520px] overflow-hidden rounded-md border border-white/10 bg-[#080B0F]">
              <div class="absolute left-4 top-4 z-10 flex flex-wrap gap-2">
                {[
                  ['pillar', 'Pillar', 'bg-[#4DB6AC]'],
                  ['commercial', 'LP', 'bg-sky-400'],
                  ['learn', 'Learn', 'bg-amber-300'],
                  ['compare', 'Compare', 'bg-violet-300'],
                  ['integration', 'Integration', 'bg-lime-300'],
                  ['trust', 'Trust', 'bg-rose-300'],
                ].map(([type, label, color]) => (
                  <span class="inline-flex items-center gap-1.5 rounded-full border border-white/10 bg-black/30 px-2.5 py-1 text-[11px] font-semibold text-gray-300">
                    <span class={`h-2 w-2 rounded-full ${color}`}></span>{label}
                  </span>
                ))}
              </div>
              <svg data-cluster-map viewBox="0 0 100 100" preserveAspectRatio="xMidYMid meet" class="h-[520px] w-full"></svg>
            </div>

            <aside class="rounded-md border border-white/10 bg-black/20 p-4">
              <p class="text-xs font-semibold uppercase tracking-widest text-[#4DB6AC]">Cluster detail</p>
              <h3 class="mt-2 text-lg font-bold text-white" data-cluster-title>Cluster</h3>
              <p class="mt-2 text-sm leading-6 text-gray-400" data-cluster-intent>Intent</p>

              <div class="mt-5 grid grid-cols-3 gap-2">
                <div class="rounded-md border border-white/10 bg-black/20 p-3">
                  <p class="text-[11px] text-gray-500">Nodes</p>
                  <p class="mt-1 text-xl font-bold text-white" data-cluster-nodes>0</p>
                </div>
                <div class="rounded-md border border-white/10 bg-black/20 p-3">
                  <p class="text-[11px] text-gray-500">Edges</p>
                  <p class="mt-1 text-xl font-bold text-white" data-cluster-edges>0</p>
                </div>
                <div class="rounded-md border border-white/10 bg-black/20 p-3">
                  <p class="text-[11px] text-gray-500">Avg</p>
                  <p class="mt-1 text-xl font-bold text-[#4DB6AC]" data-cluster-score>0</p>
                </div>
              </div>

              <div class="mt-5 rounded-md border border-white/10 bg-[#0B0D10] p-4">
                <p class="text-xs font-semibold uppercase tracking-widest text-gray-500">Selected node</p>
                <h4 class="mt-2 text-sm font-bold leading-5 text-white" data-node-title>Node</h4>
                <p class="mt-2 text-xs leading-5 text-gray-500" data-node-path>/growth/</p>
                <p class="mt-3 rounded-md border border-white/10 bg-black/20 px-3 py-2 text-xs font-semibold text-gray-300" data-node-keyword>KW</p>
                <button type="button" data-open-node-page class="mt-4 flex h-9 w-full items-center justify-center rounded-md bg-[#4DB6AC] text-xs font-bold text-white transition hover:bg-[#00897B]">このページを編集</button>
              </div>

              <div class="mt-5">
                <div class="flex items-center justify-between">
                  <h4 class="text-sm font-bold text-white">補完ポイント</h4>
                  <span class="text-xs text-gray-500">SEOの極意ベース</span>
                </div>
                <ul class="mt-3 space-y-2 text-sm leading-6 text-gray-400" data-cluster-gaps></ul>
              </div>
            </aside>
          </div>
        </section>

        <section id="section-4" class="mt-6 rounded-lg border border-white/10 bg-[#11151A] p-5">
          <div class="grid gap-5 lg:grid-cols-[320px_minmax(0,1fr)]">
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-[#4DB6AC]">Schema</p>
              <h2 class="mt-2 text-xl font-bold text-white">構造化データウィザード</h2>
              <p class="mt-3 text-sm leading-6 text-gray-400">コードを書かずに、ページタイプに応じたJSON-LDの必須項目を埋める画面です。</p>
            </div>
            <div class="grid gap-3 md:grid-cols-3">
              {['Article + FAQPage', 'Service + Breadcrumb', 'SoftwareApplication'].map((schema) => (
                <button type="button" class="rounded-md border border-white/10 bg-black/20 px-4 py-5 text-left text-sm font-semibold text-gray-200 transition hover:border-[#4DB6AC]/70 hover:text-white">{schema}</button>
              ))}
            </div>
          </div>
        </section>

        <section id="section-5" class="mt-6 rounded-lg border border-white/10 bg-[#11151A] p-5">
          <p class="text-xs font-semibold uppercase tracking-widest text-[#4DB6AC]">Indexing</p>
          <h2 class="mt-2 text-xl font-bold text-white">検索に出す/出さないを安全に決める</h2>
          <div class="mt-5 grid gap-4 md:grid-cols-3">
            {[
              ['検索に出す', 'index, follow / sitemap掲載 / self canonical'],
              ['検索に出さない', 'noindex / sitemap除外 / canonicalなし'],
              ['評価を寄せる', '301またはcanonical / noindex併用は警告'],
            ].map(([title, body]) => (
              <div class="rounded-md border border-white/10 bg-black/20 p-4">
                <h3 class="text-sm font-bold text-white">{title}</h3>
                <p class="mt-2 text-sm text-gray-400">{body}</p>
              </div>
            ))}
          </div>
        </section>
      </main>
    </div>
  </div>

  <script>
    const dataElement = document.getElementById('admin-seo-data');
    const clusterElement = document.getElementById('admin-cluster-data');
    const pages = JSON.parse(dataElement?.textContent || '[]');
    const clusters = JSON.parse(clusterElement?.textContent || '[]');
    let selectedPage = pages[0];
    let selectedCluster = clusters[0];
    let selectedNode = null;
    const draft = new Map();
    const pageByPath = new Map(pages.map((page) => [page.path, page]));

    const $ = (selector) => document.querySelector(selector);
    const $$ = (selector) => [...document.querySelectorAll(selector)];
    const svgNS = 'http://www.w3.org/2000/svg';

    const nodeMeta = {
      pillar: { fill: '#4DB6AC', stroke: '#B2DFDB', label: 'Pillar' },
      commercial: { fill: '#38BDF8', stroke: '#BAE6FD', label: 'LP' },
      learn: { fill: '#FCD34D', stroke: '#FEF3C7', label: 'Learn' },
      compare: { fill: '#C4B5FD', stroke: '#EDE9FE', label: 'Compare' },
      integration: { fill: '#BEF264', stroke: '#ECFCCB', label: 'Integration' },
      trust: { fill: '#FDA4AF', stroke: '#FFE4E6', label: 'Trust' },
    };

    const truncateLabel = (value, limit = 16) => {
      const text = String(value || '');
      return text.length > limit ? `${text.slice(0, limit - 1)}…` : text;
    };

    const svgNode = (name, attrs = {}) => {
      const node = document.createElementNS(svgNS, name);
      Object.entries(attrs).forEach(([key, value]) => node.setAttribute(key, String(value)));
      return node;
    };

    const sectionDrafts = new Map();
    let selectedSectionIndex = 0;
    let syncingEditor = false;

    const escapeHtml = (value) =>
      String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');

    const stripHtml = (value) => {
      const container = document.createElement('div');
      container.innerHTML = value || '';
      return container.textContent?.trim() || '';
    };

    const textToHtml = (value) =>
      String(value || '')
        .split(/\n{2,}/)
        .map((paragraph) => paragraph.trim())
        .filter(Boolean)
        .map((paragraph) => `<p>${escapeHtml(paragraph).replace(/\n/g, '<br>')}</p>`)
        .join('');

    const cloneSection = (section = {}) => ({
      title: section.title || '新しいセクション',
      body: section.body || stripHtml(section.bodyHtml) || '',
      bodyHtml: section.bodyHtml || textToHtml(section.body || ''),
      items: Array.isArray(section.items) ? [...section.items] : [],
      image: section.image ? { ...section.image } : { src: '', alt: '', caption: '' },
      visual: {
        layout: section.visual?.layout || (section.image?.src ? 'split-right' : 'text'),
        tone: section.visual?.tone || 'default',
        align: section.visual?.align || 'left',
        headingSize: section.visual?.headingSize || 'lg',
        bodySize: section.visual?.bodySize || 'md',
      },
    });

    const getPageSections = (page = selectedPage) => {
      if (!page) return [];
      if (!sectionDrafts.has(page.path)) {
        sectionDrafts.set(page.path, (page.sections || []).map(cloneSection));
      }
      return sectionDrafts.get(page.path);
    };

    const selectedSection = () => {
      const sections = getPageSections();
      if (!sections.length) sections.push(cloneSection());
      selectedSectionIndex = Math.min(Math.max(selectedSectionIndex, 0), sections.length - 1);
      return sections[selectedSectionIndex];
    };

    const normalizeSectionForSave = (section) => {
      const image =
        section.image?.src?.trim()
          ? {
              src: section.image.src.trim(),
              alt: section.image.alt?.trim() || section.title,
              ...(section.image.caption?.trim() ? { caption: section.image.caption.trim() } : {}),
            }
          : undefined;
      const items = (section.items || []).map((item) => item.trim()).filter(Boolean);
      return {
        title: section.title.trim() || 'Untitled section',
        body: stripHtml(section.bodyHtml) || section.body || '',
        bodyHtml: section.bodyHtml || textToHtml(section.body || ''),
        ...(items.length ? { items } : {}),
        ...(image ? { image } : {}),
        visual: section.visual || {},
      };
    };

    const healthLabel = (score) => {
      if (score >= 88) return '公開品質に近い';
      if (score >= 76) return '専門家レビュー推奨';
      return '優先改善が必要';
    };

    const actionDraft = (page, actionId) => {
      const kw = page.primaryKeyword;
      const title = page.h1;
      const related = page.related?.map((item) => `${item.label}: ${item.href}`).join('\n') || '関連ページ候補なし';
      const drafts = {
        'title-intent': `Title候補\n1. ${kw}とは？SEO/AEOで成果につなげる実践方法\n2. ${kw}の進め方｜優先順位、実装、効果検証まで\n3. ${title}｜検索意図に沿って改善するポイント`,
        'description-ctr': `Description候補\n${kw}で成果を出すために、検索意図、AIO引用、内部リンク、構造化データまで一貫して整える方法を解説します。`,
        'snippet-answer': `強調スニペット候補\n${kw}では、検索意図に合う結論をページ上部に置き、Title、description、本文、FAQを同じ主張で揃えることが重要です。`,
        'aio-summary': `AIO/AEO結論ブロック\n結論、${kw}で重要なのは、AIが引用しやすい短い回答、根拠、FAQ、構造化データを同じページ内に揃えることです。mozule growthでは、この作業をページ単位で確認し、必要な差分だけをPRとして反映します。`,
        'faq-aeo': `FAQ候補\nQ. ${kw}で最初に直すべき箇所は？\nA. Title、description、ページ冒頭の結論、FAQ、内部リンクを順に確認します。\n\nQ. AIO対策とSEO対策は別ですか？\nA. 別物ではありません。検索意図、E-E-A-T、構造化データ、内部リンクの精度を高める点で重なります。`,
        'author-proof': `E-E-A-T追加ブロック\n監修: 高取將來 / Mozule growth\n確認日: ${new Date().toISOString().slice(0, 10)}\n根拠: Search Console、公開ページ、公式ドキュメント、一次情報を確認して更新。`,
        freshness: `更新メモ\n最終更新日: ${new Date().toISOString().slice(0, 10)}\n更新理由: 検索意図、AIO引用性、内部リンク、構造化データの観点で本文とメタ情報を見直し。`,
        'context-links': `内部リンク候補\n${related}\n\n推奨アンカー: 「${kw}の改善手順」「${kw}の優先順位」「${kw}を実装へつなぐ方法」`,
        'three-click': `3クリック導線\n1. /growth/ から該当カテゴリへ\n2. カテゴリ/比較/learn一覧からこのページへ\n3. このページから関連ページへ文脈リンク`,
        'article-schema': `JSON-LD方針\nArticle、FAQPage、BreadcrumbListを出力。著者、発行元、headline、description、mainEntityOfPageを必須確認。`,
        'service-schema': `JSON-LD方針\n${page.schemaType}、FAQPage、BreadcrumbList、Organizationを出力。ページ本文にない情報はschemaへ入れない。`,
        'index-safety': `Index安全チェック\n- index対象: sitemap掲載あり、self canonical\n- noindex対象: sitemap除外、canonicalなし\n- 301対象: 旧URLから正規URLへ転送`,
        'ux-intent': `検索意図チェック\nKW: ${kw}\nTitle、description、H1、冒頭結論、CTAが同じニーズを向いているか確認。本文に関連度の低い論点を盛りすぎない。`,
      };
      return drafts[actionId] || '改善案を生成しました。';
    };

    const validateIndexing = () => {
      const status = $('[data-index-status]')?.value || 'index';
      const canonical = $('[data-canonical]')?.value.trim() || '';
      const sitemap = $('[data-sitemap]')?.checked;
      const message = $('[data-index-message]');
      if (!message) return;

      if (status === 'noindex' && sitemap) {
        message.textContent = '警告: noindexページはsitemapから除外してください。';
        message.className = 'mt-4 rounded-md border border-rose-400/30 bg-rose-500/10 px-3 py-2 text-sm text-rose-100';
        return;
      }
      if (status === 'noindex' && canonical) {
        message.textContent = '警告: noindexとcanonicalの併用は避け、どちらかに絞ってください。';
        message.className = 'mt-4 rounded-md border border-amber-400/30 bg-amber-400/10 px-3 py-2 text-sm text-amber-100';
        return;
      }
      if (status === 'index' && !sitemap) {
        message.textContent = '確認: index対象ならsitemap掲載を推奨します。';
        message.className = 'mt-4 rounded-md border border-amber-400/30 bg-amber-400/10 px-3 py-2 text-sm text-amber-100';
        return;
      }
      message.textContent = '安全です。公開前にPR差分で再確認します。';
      message.className = 'mt-4 rounded-md border border-[#4DB6AC]/30 bg-[#4DB6AC]/10 px-3 py-2 text-sm text-[#B2DFDB]';
    };

    const renderTasks = (page) => {
      const taskList = $('[data-task-list]');
      const taskCount = $('[data-task-count]');
      if (!taskList) return;
      taskList.innerHTML = '';
      taskCount.textContent = `${page.tasks.length}件`;
      page.tasks.forEach((task) => {
        const button = document.createElement('button');
        button.type = 'button';
        button.dataset.actionId = task.id;
        button.className = 'group w-full rounded-md border border-white/10 bg-black/20 p-3 text-left transition hover:border-[#4DB6AC]/70 hover:bg-[#111E20]';
        button.innerHTML = `
          <span class="flex items-center justify-between gap-3">
            <span class="text-[11px] font-semibold uppercase tracking-wide text-gray-500">${task.category}</span>
            <span class="rounded-full bg-white/5 px-2 py-0.5 text-[11px] font-semibold text-gray-400">${task.impact}</span>
          </span>
          <span class="mt-2 block text-sm font-bold leading-5 text-white">${task.label}</span>
          <span class="mt-2 block text-xs text-[#4DB6AC]">${task.oneClick}</span>
        `;
        button.addEventListener('click', () => {
          const text = actionDraft(page, task.id);
          draft.set(task.id, text);
          $('[data-draft-output]')?.remove();
          const output = document.createElement('div');
          output.dataset.draftOutput = 'true';
          output.className = 'mt-5 rounded-md border border-[#4DB6AC]/30 bg-[#4DB6AC]/10 p-4';
          output.innerHTML = `<p class="text-xs font-semibold uppercase tracking-widest text-[#4DB6AC]">Draft</p><pre class="mt-3 whitespace-pre-wrap text-sm leading-6 text-gray-100"></pre>`;
          output.querySelector('pre').textContent = text;
          taskList.after(output);
        });
        taskList.append(button);
      });
    };

    const sectionPreviewClass = (section, active = false) => {
      const visual = section.visual || {};
      const tone = visual.tone || 'default';
      const align = visual.align || 'left';
      const layout = visual.layout || 'text';
      const base = 'group w-full border-b border-white/10 px-6 py-10 text-left transition';
      const toneClass =
        tone === 'light'
          ? 'bg-white text-[#11151A]'
          : tone === 'accent'
            ? 'bg-[#4DB6AC]/10 text-white'
            : tone === 'muted'
              ? 'bg-[#0F1216] text-white'
              : 'bg-[#06080B] text-white';
      const layoutClass = layout === 'feature' ? 'md:col-span-2' : '';
      const alignClass = align === 'center' ? 'text-center' : '';
      const activeClass = active ? 'outline outline-2 outline-[#4DB6AC] outline-offset-[-2px]' : 'hover:bg-[#0F1216]';
      return [base, toneClass, layoutClass, alignClass, activeClass].filter(Boolean).join(' ');
    };

    const sectionHeadingPreviewClass = (section) => {
      const size = section.visual?.headingSize || 'lg';
      return size === 'xl' ? 'text-3xl md:text-5xl' : size === 'md' ? 'text-xl md:text-2xl' : 'text-2xl md:text-3xl';
    };

    const sectionBodyPreviewClass = (section) => {
      const size = section.visual?.bodySize || 'md';
      const tone = section.visual?.tone || 'default';
      const color = tone === 'light' ? 'text-[#263238]' : 'text-gray-300';
      const sizeClass = size === 'lg' ? 'text-lg' : size === 'sm' ? 'text-sm' : 'text-base';
      return [color, sizeClass, 'mt-4 leading-7'].join(' ');
    };

    const renderImagePreview = (section) => {
      if (section.image?.src) {
        return `
          <figure>
            <img src="${escapeHtml(section.image.src)}" alt="${escapeHtml(section.image.alt || section.title)}" class="aspect-[4/3] w-full object-cover" />
            ${section.image.caption ? `<figcaption class="mt-2 text-xs text-gray-500">${escapeHtml(section.image.caption)}</figcaption>` : ''}
          </figure>
        `;
      }
      return `
        <div class="flex aspect-[4/3] w-full items-center justify-center border border-dashed border-white/20 bg-black/20 text-xs font-semibold text-gray-500">
          画像スロット
        </div>
      `;
    };

    const renderSectionList = () => {
      const list = $('[data-section-list]');
      if (!list) return;
      const sections = getPageSections();
      list.innerHTML = '';
      sections.forEach((section, index) => {
        const button = document.createElement('button');
        button.type = 'button';
        button.dataset.sectionIndex = String(index);
        button.className = `flex w-full gap-3 rounded-md px-3 py-3 text-left transition ${
          index === selectedSectionIndex ? 'bg-[#4DB6AC]/15 text-white' : 'text-gray-400 hover:bg-white/5 hover:text-white'
        }`;
        button.innerHTML = `
          <span class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-white/10 text-[11px] font-bold">${index + 1}</span>
          <span class="min-w-0">
            <span class="block truncate text-sm font-bold">${escapeHtml(section.title)}</span>
            <span class="mt-1 block truncate text-xs text-gray-500">${escapeHtml(stripHtml(section.bodyHtml).slice(0, 72))}</span>
          </span>
        `;
        button.addEventListener('click', () => {
          syncSectionEditor();
          selectedSectionIndex = index;
          renderContentEditor();
          renderVisualCanvas();
        });
        list.append(button);
      });
    };

    const renderContentEditor = () => {
      const section = selectedSection();
      syncingEditor = true;
      $('[data-section-title]').value = section.title || '';
      $('[data-rich-editor]').innerHTML = section.bodyHtml || textToHtml(section.body || '');
      $('[data-section-items]').value = (section.items || []).join('\n');
      $('[data-section-image-src]').value = section.image?.src || '';
      $('[data-section-image-alt]').value = section.image?.alt || '';
      $('[data-section-image-caption]').value = section.image?.caption || '';
      $('[data-content-status]').textContent = `${selectedPage.path} の ${selectedSectionIndex + 1}番目の本文ブロックを編集中`;
      renderVisualInspector();
      syncingEditor = false;
    };

    const syncSectionEditor = () => {
      if (syncingEditor || !selectedPage) return;
      const section = selectedSection();
      section.title = $('[data-section-title]')?.value || section.title || '新しいセクション';
      section.bodyHtml = $('[data-rich-editor]')?.innerHTML || '';
      section.body = stripHtml(section.bodyHtml);
      section.items = ($('[data-section-items]')?.value || '')
        .split('\n')
        .map((item) => item.trim())
        .filter(Boolean);
      section.image = {
        src: $('[data-section-image-src]')?.value.trim() || '',
        alt: $('[data-section-image-alt]')?.value.trim() || section.title,
        caption: $('[data-section-image-caption]')?.value.trim() || '',
      };
      renderSectionList();
      renderVisualCanvas(false);
      renderVisualInspector();
    };

    const renderVisualInspector = () => {
      const section = selectedSection();
      const visual = section.visual || {};
      section.visual = visual;
      $('[data-visual-selected-title]').textContent = section.title || 'Section';
      $('[data-visual-layout]').value = visual.layout || 'text';
      $('[data-visual-tone]').value = visual.tone || 'default';
      $('[data-visual-align]').value = visual.align || 'left';
      $('[data-visual-heading-size]').value = visual.headingSize || 'lg';
      $('[data-visual-body-size]').value = visual.bodySize || 'md';
    };

    const renderVisualCanvas = (renderInspector = true) => {
      const canvas = $('[data-visual-canvas]');
      if (!canvas) return;
      const sections = getPageSections();
      canvas.innerHTML = '';
      sections.forEach((section, index) => {
        const visual = section.visual || {};
        const layout = visual.layout || (section.image?.src ? 'split-right' : 'text');
        const split = section.image?.src || layout === 'split-left' || layout === 'split-right';
        const sectionButton = document.createElement('button');
        sectionButton.type = 'button';
        sectionButton.dataset.visualSectionIndex = String(index);
        sectionButton.className = sectionPreviewClass(section, index === selectedSectionIndex);
        const textHtml = `
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-[#4DB6AC]">Section ${String(index + 1).padStart(2, '0')}</p>
            <h3 class="${sectionHeadingPreviewClass(section)} mt-3 font-extrabold leading-tight">${escapeHtml(section.title)}</h3>
            <div class="${sectionBodyPreviewClass(section)}">${section.bodyHtml || textToHtml(section.body || '')}</div>
            ${(section.items || []).length ? `<ul class="mt-5 space-y-2 text-sm text-gray-300">${section.items.map((item) => `<li>・${escapeHtml(item)}</li>`).join('')}</ul>` : ''}
          </div>
        `;
        if (split) {
          const imageHtml = renderImagePreview(section);
          sectionButton.innerHTML = `
            <div class="grid gap-6 md:grid-cols-2 md:items-center">
              ${layout === 'split-left' ? imageHtml : textHtml}
              ${layout === 'split-left' ? textHtml : imageHtml}
            </div>
          `;
        } else {
          sectionButton.innerHTML = textHtml;
        }
        sectionButton.addEventListener('click', () => {
          syncSectionEditor();
          selectedSectionIndex = index;
          renderSectionList();
          renderContentEditor();
          renderVisualCanvas();
        });
        canvas.append(sectionButton);
      });
      if (renderInspector) renderVisualInspector();
    };

    const refreshContentStudio = () => {
      renderSectionList();
      renderContentEditor();
      renderVisualCanvas();
    };

    const renderNodeDetail = () => {
      if (!selectedNode) return;
      const meta = nodeMeta[selectedNode.type] || nodeMeta.commercial;
      $('[data-node-title]').textContent = `${truncateLabel(selectedNode.label, 34)} / ${meta.label}`;
      $('[data-node-path]').textContent = selectedNode.path;
      $('[data-node-keyword]').textContent = `${selectedNode.keyword} / score ${selectedNode.score}`;
    };

    const renderClusterDetail = (cluster) => {
      $('[data-cluster-title]').textContent = cluster.label;
      $('[data-cluster-intent]').textContent = cluster.intent;
      $('[data-cluster-nodes]').textContent = cluster.nodeCount;
      $('[data-cluster-edges]').textContent = cluster.edgeCount;
      $('[data-cluster-score]').textContent = cluster.averageScore;

      const gaps = $('[data-cluster-gaps]');
      if (gaps) {
        gaps.innerHTML = '';
        cluster.gaps.forEach((gap) => {
          const item = document.createElement('li');
          item.className = 'flex gap-2';
          const dot = document.createElement('span');
          dot.className = 'mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[#4DB6AC]';
          const text = document.createElement('span');
          text.textContent = gap;
          item.append(dot, text);
          gaps.append(item);
        });
      }

      $$('.cluster-pick').forEach((button) => {
        const active = button.dataset.clusterId === cluster.id;
        button.className = `cluster-pick rounded-md border px-3 py-2 text-left transition ${
          active ? 'border-[#4DB6AC]/70 bg-[#4DB6AC]/15' : 'border-white/10 bg-black/20 hover:border-[#4DB6AC]/60'
        }`;
      });
      renderNodeDetail();
    };

    const renderClusterMap = (cluster) => {
      const svg = $('[data-cluster-map]');
      if (!svg || !cluster) return;
      selectedCluster = cluster;
      selectedNode = cluster.nodes.find((node) => node.path === selectedNode?.path) || cluster.nodes.find((node) => node.path === cluster.pillarPath) || cluster.nodes[0];
      svg.innerHTML = '';

      const defs = svgNode('defs');
      const glow = svgNode('filter', { id: 'node-glow', x: '-40%', y: '-40%', width: '180%', height: '180%' });
      glow.append(svgNode('feGaussianBlur', { stdDeviation: '1.2', result: 'blur' }));
      glow.append(svgNode('feMerge'));
      glow.lastChild.append(svgNode('feMergeNode', { in: 'blur' }));
      glow.lastChild.append(svgNode('feMergeNode', { in: 'SourceGraphic' }));
      defs.append(glow);
      svg.append(defs);

      [22, 34, 46].forEach((rx) => {
        svg.append(svgNode('ellipse', {
          cx: 50,
          cy: 50,
          rx,
          ry: Math.round(rx * 0.72),
          fill: 'none',
          stroke: 'rgba(255,255,255,0.07)',
          'stroke-width': 0.35,
        }));
      });

      const nodesByPath = new Map(cluster.nodes.map((node) => [node.path, node]));
      cluster.edges.forEach((edge) => {
        const source = nodesByPath.get(edge.source);
        const target = nodesByPath.get(edge.target);
        if (!source || !target) return;
        svg.append(svgNode('line', {
          x1: source.x,
          y1: source.y,
          x2: target.x,
          y2: target.y,
          stroke: edge.kind === 'pillar' ? 'rgba(77,182,172,0.35)' : 'rgba(255,255,255,0.18)',
          'stroke-width': edge.kind === 'pillar' ? 0.7 : 0.35,
          'stroke-linecap': 'round',
        }));
      });

      cluster.nodes.forEach((node) => {
        const meta = nodeMeta[node.type] || nodeMeta.commercial;
        const group = svgNode('g', { role: 'button', tabindex: '0', 'data-node-path': node.path });
        group.style.cursor = 'pointer';

        if (selectedNode?.path === node.path) {
          group.append(svgNode('circle', {
            cx: node.x,
            cy: node.y,
            r: node.radius + 2.8,
            fill: meta.fill,
            opacity: 0.14,
            filter: 'url(#node-glow)',
          }));
        }

        group.append(svgNode('circle', {
          cx: node.x,
          cy: node.y,
          r: node.radius,
          fill: meta.fill,
          stroke: selectedNode?.path === node.path ? '#FFFFFF' : meta.stroke,
          'stroke-width': selectedNode?.path === node.path ? 0.9 : 0.45,
        }));

        const score = svgNode('text', {
          x: node.x,
          y: node.y + 1.2,
          'text-anchor': 'middle',
          'font-size': node.type === 'pillar' ? 3.4 : 2.6,
          'font-weight': 800,
          fill: '#081014',
        });
        score.textContent = node.score;
        group.append(score);

        const label = svgNode('text', {
          x: node.x,
          y: node.y + node.radius + 4.3,
          'text-anchor': 'middle',
          'font-size': node.type === 'pillar' ? 3.1 : 2.25,
          'font-weight': node.type === 'pillar' ? 800 : 650,
          fill: node.type === 'pillar' ? '#EFFFFD' : '#D1D5DB',
        });
        label.textContent = truncateLabel(node.keyword || node.label, node.type === 'pillar' ? 18 : 14);
        group.append(label);

        group.addEventListener('click', () => {
          selectedNode = node;
          const page = pageByPath.get(node.path);
          if (page) renderPage(page);
          renderClusterMap(cluster);
        });
        group.addEventListener('keydown', (event) => {
          if (event.key === 'Enter' || event.key === ' ') {
            event.preventDefault();
            group.dispatchEvent(new Event('click'));
          }
        });
        svg.append(group);
      });

      renderClusterDetail(cluster);
    };

    const renderPage = (page) => {
      selectedPage = page;
      $('[data-page-title]').textContent = page.title;
      $('[data-page-path]').textContent = page.path;
      $('[data-page-score]').textContent = page.score;
      $('[data-page-health]').textContent = healthLabel(page.score);
      $('[data-page-schema]').textContent = page.schemaType;
      $$('[data-field]').forEach((input) => {
        input.value = page[input.dataset.field] || '';
      });
      $('[data-canonical]').value = page.path;
      $('[data-index-status]').value = 'index';
      $('[data-sitemap]').checked = true;
      renderTasks(page);
      validateIndexing();
      selectedSectionIndex = 0;
      refreshContentStudio();
    };

    $$('[data-page-row], .page-pick').forEach((row) => {
      row.addEventListener('click', () => {
        const index = Number(row.dataset.pageIndex);
        if (!Number.isNaN(index) && pages[index]) renderPage(pages[index]);
      });
    });

    $$('.cluster-pick').forEach((button) => {
      button.addEventListener('click', () => {
        const cluster = clusters.find((item) => item.id === button.dataset.clusterId);
        if (cluster) renderClusterMap(cluster);
      });
    });

    $('[data-open-node-page]')?.addEventListener('click', () => {
      const page = pageByPath.get(selectedNode?.path);
      if (!page) return;
      renderPage(page);
      document.getElementById('section-1')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    $$('[data-format-block]').forEach((button) => {
      button.addEventListener('click', () => {
        $('[data-rich-editor]')?.focus();
        document.execCommand('formatBlock', false, button.dataset.formatBlock);
        syncSectionEditor();
      });
    });

    $$('[data-rich-command]').forEach((button) => {
      button.addEventListener('click', () => {
        $('[data-rich-editor]')?.focus();
        document.execCommand(button.dataset.richCommand, false, null);
        syncSectionEditor();
      });
    });

    $('[data-rich-link]')?.addEventListener('click', () => {
      $('[data-rich-editor]')?.focus();
      const href = window.prompt('リンクURLを入力してください', '/growth/');
      if (!href) return;
      document.execCommand('createLink', false, href);
      syncSectionEditor();
    });

    $$('[data-section-title], [data-section-items], [data-section-image-src], [data-section-image-alt], [data-section-image-caption]').forEach((field) => {
      field.addEventListener('input', syncSectionEditor);
    });

    $('[data-rich-editor]')?.addEventListener('input', syncSectionEditor);

    $('[data-section-add]')?.addEventListener('click', () => {
      syncSectionEditor();
      const sections = getPageSections();
      sections.splice(selectedSectionIndex + 1, 0, cloneSection({ title: '新しいセクション', body: 'ここに本文を入力します。' }));
      selectedSectionIndex += 1;
      refreshContentStudio();
    });

    $('[data-section-duplicate]')?.addEventListener('click', () => {
      syncSectionEditor();
      const sections = getPageSections();
      sections.splice(selectedSectionIndex + 1, 0, cloneSection(selectedSection()));
      selectedSectionIndex += 1;
      refreshContentStudio();
    });

    $('[data-section-delete]')?.addEventListener('click', () => {
      const sections = getPageSections();
      if (sections.length <= 1) return;
      sections.splice(selectedSectionIndex, 1);
      selectedSectionIndex = Math.max(0, selectedSectionIndex - 1);
      refreshContentStudio();
    });

    $('[data-section-up]')?.addEventListener('click', () => {
      syncSectionEditor();
      const sections = getPageSections();
      if (selectedSectionIndex <= 0) return;
      [sections[selectedSectionIndex - 1], sections[selectedSectionIndex]] = [sections[selectedSectionIndex], sections[selectedSectionIndex - 1]];
      selectedSectionIndex -= 1;
      refreshContentStudio();
    });

    $('[data-section-down]')?.addEventListener('click', () => {
      syncSectionEditor();
      const sections = getPageSections();
      if (selectedSectionIndex >= sections.length - 1) return;
      [sections[selectedSectionIndex + 1], sections[selectedSectionIndex]] = [sections[selectedSectionIndex], sections[selectedSectionIndex + 1]];
      selectedSectionIndex += 1;
      refreshContentStudio();
    });

    [
      ['[data-visual-layout]', 'layout'],
      ['[data-visual-tone]', 'tone'],
      ['[data-visual-align]', 'align'],
      ['[data-visual-heading-size]', 'headingSize'],
      ['[data-visual-body-size]', 'bodySize'],
    ].forEach(([selector, key]) => {
      $(selector)?.addEventListener('change', (event) => {
        const section = selectedSection();
        section.visual = section.visual || {};
        section.visual[key] = event.target.value;
        renderVisualCanvas(false);
        renderSectionList();
      });
    });

    $('[data-page-search]')?.addEventListener('input', (event) => {
      const query = event.target.value.toLowerCase();
      $$('[data-page-row]').forEach((row) => {
        row.hidden = !row.dataset.search.toLowerCase().includes(query);
      });
    });

    $$('[data-index-status], [data-canonical], [data-sitemap]').forEach((control) => {
      control.addEventListener('input', validateIndexing);
      control.addEventListener('change', validateIndexing);
    });

    $('[data-copy-plan]')?.addEventListener('click', async () => {
      const changes = [...draft.values()].join('\n\n---\n\n') || 'まだ改善案は生成されていません。';
      await navigator.clipboard?.writeText(changes);
    });

    $('[data-submit-proposal]')?.addEventListener('click', async () => {
      syncSectionEditor();
      const status = $('[data-submit-status]');
      const button = $('[data-submit-proposal]');
      const payload = {
        path: $('[data-field="path"]')?.value || selectedPage.path,
        title: $('[data-field="title"]')?.value || selectedPage.title,
        description: $('[data-field="description"]')?.value || selectedPage.description,
        primaryKeyword: $('[data-field="primaryKeyword"]')?.value || selectedPage.primaryKeyword,
        lede: $('[data-field="lede"]')?.value || selectedPage.lede,
        sections: getPageSections(selectedPage).map(normalizeSectionForSave),
        indexStatus: $('[data-index-status]')?.value || 'index',
        canonical: $('[data-canonical]')?.value || '',
        sitemap: Boolean($('[data-sitemap]')?.checked),
        notes: [...draft.values()].join('\n\n---\n\n'),
      };

      status.textContent = 'PR作成リクエストを送信しています...';
      status.className = 'mt-3 min-h-10 rounded-md border border-[#4DB6AC]/30 bg-[#4DB6AC]/10 px-3 py-2 text-xs leading-5 text-[#B2DFDB]';
      button.disabled = true;

      try {
        const response = await fetch('/api/admin/proposals', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const result = await response.json();

        if (!response.ok || !result.ok) {
          throw new Error(result.message || 'PR作成に失敗しました。');
        }

        if (result.prUrl) {
          status.innerHTML = `<a class="font-semibold text-[#4DB6AC] underline" href="${result.prUrl}" target="_blank" rel="noreferrer">GitHub PRを開く</a>`;
        } else {
          status.textContent = result.message || 'dry-runとして差分案を生成しました。GITHUB_TOKEN設定後にPR化できます。';
        }
      } catch (error) {
        status.textContent = error.message || 'PR作成リクエストに失敗しました。';
        status.className = 'mt-3 min-h-10 rounded-md border border-amber-400/30 bg-amber-400/10 px-3 py-2 text-xs leading-5 text-amber-100';
      } finally {
        button.disabled = false;
      }
    });

    renderPage(pages[0]);
    renderClusterMap(clusters[0]);
  </script>
</AdminLayout>
