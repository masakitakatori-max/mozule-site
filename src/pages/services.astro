---
import Layout from '../layouts/Layout.astro';
const services = [
  {
    title: '新規事業開発支援',
    description: '事業アイデアの検証から、MVP開発、グロースまで。スタートアップに必要な検証サイクルを最速で回します。',
    details: ['事業仮説の策定・検証設計', 'MVP（Minimum Viable Product）の開発', 'ユーザーインタビュー・市場調査', 'ピボット判断の支援', 'KPI設計・トラッキング基盤の構築'],
  },
  {
    title: 'AIシステムの開発支援',
    description: '生成AIを活用したプロダクト開発。データ分析基盤の構築から、AIエージェントの実装まで対応します。',
    details: ['生成AI（LLM）を活用したアプリケーション開発', 'AIエージェント・ワークフローの設計・構築', 'データ分析基盤の設計・実装', '機械学習モデルの開発・運用', '既存システムへのAI機能の統合'],
  },
  {
    title: 'マーケティング / 営業支援',
    description: 'SEO、コンテンツマーケティング、営業戦略の立案から実行まで。データドリブンなグロースを実現します。',
    details: ['SEO戦略の策定・コンテンツ制作', 'Web広告の運用・最適化', '営業戦略の立案・KPI設計', 'CRM/SFA導入・運用支援', 'データドリブンなグロース施策の実行'],
  },
];
---
<Layout title="事業内容">
  <section class="pt-32 pb-16 px-6 relative">
    <div class="max-w-3xl mx-auto text-center fade-up">
      <p class="text-sm tracking-widest uppercase text-[#4DB6AC] mb-4 font-medium">Services</p>
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white leading-tight mb-6">事業内容</h1>
      <p class="text-gray-400 max-w-xl mx-auto leading-relaxed">テクノロジーとビジネスの両面から、あなたの事業成長を支援します。</p>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#1E1E1E] to-transparent"></div>
  </section>

  <section class="py-24 md:py-32 px-6">
    <div class="max-w-4xl mx-auto space-y-16">
      {services.map((s, i) => (
        <div class="fade-up border border-[#1E1E1E] rounded-2xl p-8 md:p-12 bg-[#0F0F0F]">
          <p class="text-xs tracking-widest uppercase text-gray-500 mb-1 font-medium">0{i + 1}</p>
          <h2 class="text-2xl font-bold text-white mb-4">{s.title}</h2>
          <p class="text-gray-400 leading-relaxed mb-8">{s.description}</p>
          <ul class="space-y-3">
            {s.details.map((d) => (
              <li class="flex items-start gap-3 text-sm text-gray-300">
                <span class="text-[#4DB6AC] mt-0.5">✓</span>
                {d}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto text-center fade-up">
      <p class="text-gray-400 mb-6">サービスに関するご相談はお気軽にお問い合わせください。</p>
      <a href="mailto:org-owner@mozule.co.jp" class="inline-block bg-[#4DB6AC] hover:bg-[#00897B] text-white font-semibold px-8 py-4 rounded-lg transition">
        お問い合わせ
      </a>
    </div>
  </section>
</Layout>
