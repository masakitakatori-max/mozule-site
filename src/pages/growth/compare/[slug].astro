---
import GrowthContentPage from '../../../components/GrowthContentPage.astro';
import { comparePages } from '../../../data/growth';

export function getStaticPaths() {
  return comparePages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
---
<GrowthContentPage page={page} parent={{ label: 'Compare', href: '/growth/compare/' }} />

