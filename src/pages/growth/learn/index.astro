---
import Layout from '../../../layouts/Layout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { breadcrumbJson, learnArticles, organizationJson, growthSoftwareJson } from '../../../data/growth';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'mozule growth', href: '/growth/' },
  { label: 'Learn', href: '/growth/learn/' },
];
const clusters = [
  { slug: 'aeo', label: 'AEO / AI検索' },
  { slug: 'startup-seo', label: 'スタートアップSEO' },
  { slug: 'seo', label: 'SEO改善' },
  { slug: 'mcp', label: 'MCP / GitHub' },
  { slug: 'growth', label: 'Growth Loop' },
];
---
<Layout
  section="growth"
  title="ナレッジ"
  description="mozule growthのSEO、AEO、MCP、スタートアップSEO、グロースループに関するナレッジ記事です。"
  canonicalPath="/growth/learn/"
  structuredData={[organizationJson, growthSoftwareJson('/growth/'), breadcrumbJson(breadcrumbs)]}
>
  <Breadcrumbs items={breadcrumbs} />
  <section class="px-6 py-20 md:py-28">
    <div class="max-w-6xl mx-auto">
      <p class="text-sm tracking-widest uppercase text-[#4DB6AC] mb-4 font-medium">Learn</p>
      <h1 class="text-4xl md:text-6xl font-extrabold text-white mb-7">ナレッジ</h1>
      <p class="max-w-2xl text-gray-400 leading-relaxed mb-12">
        Founder、CTO、初期グロース担当が、SEO/AEO改善を実装へつなげるための基礎を整理しています。
      </p>
      <div class="grid gap-4 md:grid-cols-3">
        {clusters.map((cluster) => (
          <a href={`/growth/learn/${cluster.slug}/`} class="rounded-lg border border-[#1E1E1E] p-6 transition hover:border-[#4DB6AC] hover:-translate-y-0.5">
            <h2 class="text-xl font-bold text-white mb-3">{cluster.label}</h2>
            <p class="text-sm text-gray-400 leading-relaxed">
              {learnArticles.filter((page) => page.path.includes(`/learn/${cluster.slug}/`)).length}本の記事
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

