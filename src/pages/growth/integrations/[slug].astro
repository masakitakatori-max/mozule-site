---
import GrowthContentPage from '../../../components/GrowthContentPage.astro';
import { integrationPages } from '../../../data/growth';

export function getStaticPaths() {
  return integrationPages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
---
<GrowthContentPage page={page} parent={{ label: 'Integrations', href: '/growth/integrations/' }} />

