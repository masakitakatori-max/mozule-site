---
import Layout from '../layouts/Layout.astro';
const news = [
  { date: '2026年1月', category: 'プレスリリース', title: '株式会社Mozuleを設立', body: '「関わるすべての人が発信源となり、喜びが循環する仕組みを作る」をミッションに掲げ、東京都目黒区に株式会社Mozuleを設立しました。' },
];
---
<Layout
  title="ニュース"
  description="株式会社Mozuleのニュース一覧です。会社設立やサービスに関する最新情報を掲載しています。"
  canonicalPath="/news/"
>
  <section class="pt-32 pb-16 px-6 relative">
    <div class="max-w-3xl mx-auto text-center fade-up">
      <p class="text-sm tracking-widest uppercase text-[#4DB6AC] mb-4 font-medium">News</p>
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white leading-tight">ニュース</h1>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#1E1E1E] to-transparent"></div>
  </section>

  <section class="py-24 md:py-32 px-6">
    <div class="max-w-3xl mx-auto">
      <div class="space-y-6">
        {news.map((item) => (
          <article class="fade-up border border-[#1E1E1E] rounded-xl p-8 bg-[#0F0F0F] hover:border-[#4DB6AC]/40 transition">
            <div class="flex items-center gap-4 mb-4">
              <time class="text-xs text-gray-500 font-medium">{item.date}</time>
              <span class="text-xs px-2 py-0.5 rounded-full bg-[#4DB6AC]/10 text-[#4DB6AC] font-medium">{item.category}</span>
            </div>
            <h2 class="text-lg font-bold text-white mb-3">{item.title}</h2>
            <p class="text-gray-400 text-sm leading-relaxed">{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
